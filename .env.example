# Database
DATABASE_URL=postgresql+asyncpg://restext:restext@localhost:5432/restext

# Qdrant (use QDRANT_PATH for local file storage, or QDRANT_URL for server)
QDRANT_PATH=./.qdrant_data
# QDRANT_URL=http://localhost:6333

# Redis
REDIS_URL=redis://localhost:6379

# OpenAI (for embeddings)
OPENAI_API_KEY=sk-...

# App
APP_ENV=development
